#include <iostream>
#include <string>
using namespace std;

// ======= QUEUE STRUCTURE =======
// Queue works as First In First Out (FIFO)
// It reads the DNA sequence from left to right
struct Queue {
    char data[100]; // Array to store DNA characters
    int front, rear; // front = start of queue, rear = end of queue

    // Constructor: starts the queue empty
    Queue() { front = 0; rear = 0; }

    // enqueue: adds a character to the END of the queue
    void enqueue(char c) { data[rear++] = c; }

    // dequeue: removes and returns character from the FRONT of the queue
    char dequeue() { return data[front++]; }

    // isEmpty: returns true if queue has no characters
    bool isEmpty() { return front == rear; }
};

// ======= STACK STRUCTURE =======
// Stack works as Last In First Out (LIFO)
// It stores the first half of DNA and checks pairs
struct Stack {
    char data[100]; // Array to store DNA characters
    int top; // top points to the last added character

    // Constructor: top = -1 means stack is empty
    Stack() { top = -1; }

    // push: adds a character to the TOP of the stack
    void push(char c) { data[++top] = c; }

    // pop: removes and returns character from the TOP of the stack
    char pop() { return data[top--]; }

    // isEmpty: returns true if stack has no characters
    bool isEmpty() { return top == -1; }

    // display: shows the current stack content on screen
    void display() {
        cout << "Stack: [ ";
        for (int i = 0; i <= top; i++)
            cout << data[i] << " ";
        cout << "]" << endl;
    }
};

// ======= isMatch FUNCTION =======
// Checks if two DNA characters are a valid pair
// Valid pairs are: A with T, T with A, C with G, G with C
bool isMatch(char a, char b) {
    return (a=='A' && b=='T') || (a=='T' && b=='A') ||
           (a=='C' && b=='G') || (a=='G' && b=='C');
}

// ======= MAIN FUNCTION =======
int main() {
    string dna; // Variable to store the DNA sequence

    // Display the program title
    cout << "==============================" << endl;
    cout << "     DNA Sequence Checker     " << endl;
    cout << "     Using Stack + Queue      " << endl;
    cout << "==============================" << endl;
    cout << endl;

    // Ask user to enter DNA sequence
    cout << "Enter DNA sequence (e.g. ATCGGCTA): ";
    cin >> dna;

    // Check if the length is even
    // DNA must have equal two halves to check pairs
    if (dna.length() % 2 != 0) {
        cout << "\nError! DNA length must be even!" << endl;
        return 0;
    }

    // Check for invalid characters
    // Only A, T, C, G are allowed in DNA
    for (int i = 0; i < dna.length(); i++) {
        dna[i] = toupper(dna[i]); // Convert to uppercase
        if (dna[i]!='A' && dna[i]!='T' && dna[i]!='C' && dna[i]!='G') {
            cout << "\nError! Invalid character '" << dna[i] << "'!" << endl;
            cout << "Only A, T, C, G are allowed!" << endl;
            return 0;
        }
    }

    // Create Queue and Stack objects
    Queue q;
    Stack s;

    // ======= STEP 1: Load DNA into Queue =======
    // All characters are added to the queue one by one
    cout << "\nStep 1: Loading DNA into Queue..." << endl;
    for (int i = 0; i < dna.length(); i++)
        q.enqueue(dna[i]);

    // Show the queue content
    cout << "Queue: [ ";
    for (int i = 0; i < dna.length(); i++)
        cout << dna[i] << " ";
    cout << "]" << endl;

    // Calculate the middle of the DNA sequence
    int half = dna.length() / 2;

    // ======= STEP 2: Push first half into Stack =======
    // Take first half from Queue and push into Stack
    cout << "\nStep 2: Pushing first half into Stack..." << endl;
    for (int i = 0; i < half; i++) {
        s.push(q.dequeue()); // Take from Queue, push to Stack
        s.display(); // Show Stack after each push
    }

    // ======= STEP 3: Check pairs =======
    // Pop from Stack and compare with second half from Queue
    cout << "\nStep 3: Checking pairs..." << endl;
    bool valid = true; // Assume valid until we find an error

    while (!q.isEmpty() && !s.isEmpty()) {
        char fromQueue = q.dequeue(); // Get next character from Queue
        char fromStack = s.pop();     // Get top character from Stack

        // Compare the two characters
        cout << "Comparing: " << fromStack << " with " << fromQueue;

        if (isMatch(fromStack, fromQueue))
            cout << " -> Match! OK" << endl;
        else {
            cout << " -> No Match! ERROR" << endl;
            valid = false; // Found an invalid pair
        }
    }

    // ======= RESULT =======
    // Show final result based on all comparisons
    cout << "\n==============================" << endl;
    if (valid)
        cout << "Result: Valid DNA Sequence! :)" << endl;
    else
        cout << "Result: Invalid DNA Sequence! :(" << endl;
    cout << "==============================" << endl;

    return 0; // Program ends successfully
}
